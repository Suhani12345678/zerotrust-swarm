# ══════════════════════════════════════════════════════════════
# ZeroTrust-Swarm — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ══════════════════════════════════════════════════════════════

# ── Security ───────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
CALLER_API_KEY=                    # Optional: set to protect /inspect endpoint

# ── LLM — Priority 1: GitHub Models (Azure OpenAI GPT-4o) ─────
# Get free token: https://github.com/marketplace/models
# This IS Azure infrastructure — counts as Microsoft AI stack
GITHUB_TOKEN=your_github_token_here

# ── LLM — Priority 2: Groq (fallback, also free) ──────────────
# Get free key: https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# If NEITHER key is set → rule-based semantic engine runs (always-on, no API needed)

# ── Azure Production Stack (for judges / final deployment) ────
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_KEY=your_azure_openai_key
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# COSMOS_URL=https://your-account.documents.azure.com:443/
# COSMOS_KEY=your_cosmos_key
# COSMOS_DATABASE=zerotrust
# COSMOS_CONTAINER=events

# ── Frontend URL (for CORS in production) ─────────────────────
# ALLOWED_ORIGIN=https://your-app.vercel.app,https://your-app.railway.app
